---
import Heading from "./heading.astro";
import logo from "../img/logo_belma.svg";

const navItems = [
  { label: "MENU", href: "/menu" },
  { label: "RESERVATIONS", href: "/reservations" },
  { label: "EVENTS", href: "/events" },
  { label: "ABOUT US", href: "/about_us" },
];
---

<header class="w-full px-4 pb-6 pt-3 md:px-6 md:pb-8 md:pt-4 lg:px-12 lg:pb-14 lg:pt-6">
  <div class="mx-auto max-w-[1370px] border border-primary py-5 pl-4 pr-5 md:flex md:min-h-[104px] md:items-center md:justify-between md:gap-8 md:px-8 lg:min-h-[138px] lg:pl-[70px] lg:pr-[112px]">
    <div class="flex items-center justify-between">
      <a href="/" aria-label="Belma forside" class="shrink-0">
        <img
          src={logo.src}
          alt="Belma"
          class="h-auto w-[200px] md:w-[210px] lg:w-[310px]"
        />
      </a>

      <button
        id="mobile-menu-button"
        class="group flex h-11 w-11 flex-col items-center justify-center gap-1.5 md:hidden"
        type="button"
        aria-label="Åbn menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="h-[3px] w-8 bg-secondary transition-transform duration-200 group-hover:scale-x-125"></span>
        <span class="h-[3px] w-8 bg-secondary transition-transform duration-200 group-hover:scale-x-125"></span>
        <span class="h-[3px] w-8 bg-secondary transition-transform duration-200 group-hover:scale-x-125"></span>
      </button>
    </div>

    <nav
      id="mobile-menu"
      class="hidden pt-8 md:block md:pt-0"
      aria-label="Hovedmenu"
    >
      <ul class="flex flex-col gap-5 md:flex-row md:flex-wrap md:items-center md:justify-end md:gap-x-6 md:gap-y-3 lg:flex-nowrap lg:gap-10">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="block text-secondary transition-colors hover:text-primary"
            >
              <Heading type="labelLarge" stylingclasses="leading-none">
                {item.label}
              </Heading>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  if (btn && menu) {
    btn.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");

      menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!isOpen));
    });
  }
</script>
