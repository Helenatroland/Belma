---
import Heading from "./heading.astro";
import logo from "../img/logo_belma.svg";

const navItems = [
  { label: "MENU", href: "/menu" },
  { label: "RESERVATIONS", href: "/reservations" },
  { label: "EVENTS", href: "/events" },
  { label: "ABOUT US", href: "/about_us" },
];
---

<header class="w-full pb-3 md:pb-4 lg:pb-5">
  <div class="w-full border-[1.5px] border-primary px-4 pt-4 pb-3 md:flex md:min-h-23 md:items-center md:justify-between md:gap-8 md:px-8 md:pt-5 md:pb-4 lg:min-h-29.5 lg:pl-17.5 lg:pr-28 lg:pt-6 lg:pb-4">
    <div class="flex items-center justify-between">
      <a href="/" aria-label="Belma forside" class="shrink-0">
        <img
          src={logo.src}
          alt="Belma"
          class="h-auto w-42.5 md:w-47.5 lg:w-65"
        />
      </a>

      <button
        id="mobile-menu-button"
        class="group flex h-11 w-11 flex-col items-center justify-center gap-1.5 md:hidden"
        type="button"
        aria-label="Åbn menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="h-0.75 w-8 bg-secondary transition-transform duration-200 group-hover:scale-x-125"></span>
        <span class="h-0.75 w-8 bg-secondary transition-transform duration-200 group-hover:scale-x-125"></span>
        <span class="h-0.75 w-8 bg-secondary transition-transform duration-200 group-hover:scale-x-125"></span>
      </button>
    </div>

    <nav
      id="mobile-menu"
      class="hidden pt-6 md:block md:pt-0"
      aria-label="Hovedmenu"
    >
      <ul class="flex flex-col gap-4 md:flex-row md:flex-wrap md:items-center md:justify-end md:gap-x-6 md:gap-y-3 lg:flex-nowrap lg:gap-10">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="block text-secondary transition-colors hover:text-primary"
            >
              <Heading type="labelLarge" stylingclasses="leading-none">
                {item.label}
              </Heading>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  if (btn && menu) {
    btn.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");

      menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!isOpen));
    });
  }
</script>
