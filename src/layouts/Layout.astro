---
import "../styles/global.css";
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";

import background from "../img/background.webp";

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="da">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
<link rel="manifest" href="/favicon/site.webmanifest">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link
      href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Outfit:wght@100..900&family=Space+Grotesk:wght@300..700&family=Special+Elite&display=swap"
      rel="stylesheet"
    >

    <!-- Intersect plugin -->
    <script
      defer
      src="https://unpkg.com/tailwindcss-intersect@2.x.x/dist/observer.min.js">
    </script>
  </head>

  <body
    style={`
      font-family: 'Outfit', sans-serif;
      color: #000;
      background-image: url(${background.src});
      background-size: 115%;
      background-position: center center;
      background-repeat: repeat-y;
      background-attachment: fixed;
      min-height: 100vh;
    `}
  >
    <Header />
    <slot />
    <Footer />
  </body>
</html>
