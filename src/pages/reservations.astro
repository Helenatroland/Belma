---
import Layout from '../layouts/Layout.astro';
import Heading from '../components/heading.astro';
import Text from '../components/text.astro';
import Button from '../components/button.astro';
---

<Layout title="Reservations">
  <main>
    <!-- section 1 -->
    <section class="w-full px-4 md:px-8 lg:px-12">
      <div class="mx-auto max-w-245">
        <Heading type="h1" stylingclasses="text-center pt-5 pb-14">
          RESERVATIONS
        </Heading>

        <Heading type="h2" stylingclasses="font-bold py-5">
          The Door’s Open - Swing By Anytime
        </Heading>

        <Text> 
          We always love a good walk-in, so feel free to drop by whenever the mood strikes. Whether it’s for breakfast, lunch, after-work drinks, or a spontaneous night out, there’s always a place for you at Belma.
          <br />
          <br />
          If you’d rather plan ahead, we’re more than happy to reserve a table for you and your group. For regular bookings, simply fill out the form below and we’ll take care of the rest.
          <br />
          Planning something bigger? For groups of 10 or more, celebrations, private gatherings, or any special requests, just send us an email at 1650@belma.dk with the following details:
          <br />
          <br />
          1. Type of event
          <br />
          2. Number of guests
          <br />
          3. Preferred date & time
          <br />
          <br />
          We’ll get back to you within 24 hours - usually even faster.
        </Text>

        <Heading type="h3" stylingclasses="font-medium py-5">
          See you soon at Belma.
        </Heading>
      </div>
    </section>

    <!-- section 2 -->
    <section class="w-full px-4 pt-10 pb-28 md:px-8 md:pb-36 lg:px-12 lg:pb-44">
      <form class="mx-auto w-full max-w-140">
        <div class="mb-16">
          <label for="date">
            <Heading type="labelLarge" stylingclasses="mb-2 leading-none">
              CHOOSE DATE
            </Heading>
          </label>

          <input
            id="date"
            name="date"
            type="date"
            class="h-25 w-full bg-secondary px-4 font-space text-primary outline-none"
          />
        </div>

        <div class="mb-16">
          <label for="people">
            <Heading type="labelLarge" stylingclasses="mb-2 leading-none">
              NUMBER OF PEOPLE
            </Heading>
          </label>

          <input
            id="people"
            name="people"
            type="number"
            min="1"
            class="h-25 w-full bg-secondary px-4 font-space text-primary outline-none"
          />
        </div>

        <div class="mb-16">
          <label for="time">
            <Heading type="labelLarge" stylingclasses="mb-2 leading-none">
              CHOOSE TIME
            </Heading>
          </label>

          <input
            id="time"
            name="time"
            type="time"
            class="h-25 w-full bg-secondary px-4 font-space text-primary outline-none"
          />
        </div>

        <div class="mb-12">
          <Heading type="labelLarge" stylingclasses="mb-2 leading-none">
            YOUR INFORMATION
          </Heading>

          <div class="flex flex-col gap-10">
            <input
              type="text"
              name="name"
              placeholder="NAME"
              class="h-12.5 w-full bg-secondary px-3 font-space text-primary placeholder:text-primary/70 outline-none"
            />

            <input
              type="email"
              name="email"
              placeholder="E-MAIL"
              class="h-12.5 w-full bg-secondary px-3 font-space text-primary placeholder:text-primary/70 outline-none"
            />

            <input
              type="tel"
              name="phone"
              placeholder="PHONE (+45)"
              class="h-12.5 w-full bg-secondary px-3 font-space text-primary placeholder:text-primary/70 outline-none"
            />

            <input
              type="text"
              name="remarks"
              placeholder="OTHER REMARKS"
              class="h-12.5 w-full bg-secondary px-3 font-space text-primary placeholder:text-primary/70 outline-none"
            />
          </div>
        </div>

        <div class="flex w-full justify-center">
          <div class="flex w-60 justify-center">
            <Button variant="primary">
              BOOK
            </Button>
          </div>
        </div>
      </form>
    </section>
    
  </main>
</Layout>

