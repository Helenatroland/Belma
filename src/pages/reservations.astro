---
import Layout from '../layouts/Layout.astro';
import Heading from '../components/heading.astro';
import Text from '../components/text.astro';
import Button from '../components/button.astro';
---

<Layout title="Reservations">
  <main>

    <!-- section 1 -->
    <section class="w-full px-4 pt-12 md:px-8 md:pt-16 lg:px-12 lg:pt-20">

      <div class="mx-auto max-w-245">

        <Heading
          type="h1"
          stylingclasses="pb-10 text-center md:pb-14"
        >
          RESERVATIONS
        </Heading>

        <Heading
          type="h2"
          stylingclasses="py-5 text-[28px] font-bold leading-tight"
        >
          The Door’s Open - Swing By Anytime
        </Heading>

        <Text>
          We always love a good walk-in, so feel free to drop by whenever the mood strikes. Whether it’s for breakfast, lunch, after-work drinks, or a spontaneous night out, there’s always a place for you at Belma.

          <br />
          <br />

          If you’d rather plan ahead, we’re more than happy to reserve a table for you and your group. For regular bookings, simply fill out the form below and we’ll take care of the rest.

          <br />
          <br />

          Planning something bigger? For groups of 10 or more, celebrations, private gatherings, or any special requests, just send us an email at 1650@belma.dk with the following details:

          <br />
          <br />

          1. Type of event
          <br />
          2. Number of guests
          <br />
          3. Preferred date & time

          <br />
          <br />

          We’ll get back to you within 24 hours - usually even faster.
        </Text>

        <Heading
          type="h3"
          stylingclasses="py-8 text-[24px] font-medium leading-tight md:py-10"
        >
          See you soon at Belma.
        </Heading>

      </div>

    </section>

    <!-- section 2 -->
    <section class="w-full px-4 pt-8 pb-32 md:px-8 md:pt-10 md:pb-40 lg:px-12 lg:pb-48">

      <form class="mx-auto w-full max-w-140">

        <!-- date -->
        <div class="mb-12 md:mb-16">

          <label for="date">

            <Heading
              type="labelLarge"
              stylingclasses="mb-3 leading-none"
            >
              CHOOSE DATE
            </Heading>

          </label>

          <input
            id="date"
            name="date"
            type="date"
            class="h-18 w-full bg-secondary px-4 text-[15px] font-space text-primary outline-none md:h-22 lg:h-25"
          />

        </div>

        <!-- people -->
        <div class="mb-12 md:mb-16">

          <label for="people">

            <Heading
              type="labelLarge"
              stylingclasses="mb-3 leading-none"
            >
              NUMBER OF PEOPLE
            </Heading>

          </label>

          <input
            id="people"
            name="people"
            type="number"
            min="1"
            class="h-18 w-full bg-secondary px-4 text-[15px] font-space text-primary outline-none md:h-22 lg:h-25"
          />

        </div>

        <!-- time -->
        <div class="mb-12 md:mb-16">

          <label for="time">

            <Heading
              type="labelLarge"
              stylingclasses="mb-3 leading-none"
            >
              CHOOSE TIME
            </Heading>

          </label>

          <input
            id="time"
            name="time"
            type="time"
            class="h-18 w-full bg-secondary px-4 text-[15px] font-space text-primary outline-none md:h-22 lg:h-25"
          />

        </div>

        <!-- information -->
        <div class="mb-12">

          <Heading
            type="labelLarge"
            stylingclasses="mb-4 leading-none"
          >
            YOUR INFORMATION
          </Heading>

          <div class="flex flex-col gap-6 md:gap-8 lg:gap-10">

            <input
              type="text"
              name="name"
              placeholder="NAME"
              class="h-12 w-full bg-secondary px-4 text-[15px] font-space text-primary placeholder:text-primary/70 outline-none md:h-13"
            />

            <input
              type="email"
              name="email"
              placeholder="E-MAIL"
              class="h-12 w-full bg-secondary px-4 text-[15px] font-space text-primary placeholder:text-primary/70 outline-none md:h-13"
            />

            <input
              type="tel"
              name="phone"
              placeholder="PHONE (+45)"
              class="h-12 w-full bg-secondary px-4 text-[15px] font-space text-primary placeholder:text-primary/70 outline-none md:h-13"
            />

            <input
              type="text"
              name="remarks"
              placeholder="OTHER REMARKS"
              class="h-12 w-full bg-secondary px-4 text-[15px] font-space text-primary placeholder:text-primary/70 outline-none md:h-13"
            />

          </div>

        </div>

        <!-- button -->
        <div class="flex w-full justify-center pt-2 md:pt-4">

          <Button
            variant="primary"
            stylingclasses="px-12 py-3 font-bold md:px-15"
          >
            BOOK
          </Button>

        </div>

      </form>

    </section>

  </main>
</Layout>