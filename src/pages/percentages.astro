---
import Layout from '../layouts/Layout.astro';
import Heading from '../components/heading.astro';
---

<Layout title="Percentages">
  <main>

    <section class="w-full px-4 pt-12 pb-20 md:px-8 md:pt-16 md:pb-24 lg:px-12 lg:pt-20 lg:pb-28">

      <div class="mx-auto w-full max-w-125">

        <div class="relative pb-20">

          <!-- arrows -->
          <button
            id="prev-card"
            type="button"
            aria-label="Forrige kort"
            class="absolute left-0 top-0 z-10 font-special text-5xl leading-none text-neutral-black md:text-7xl"
          >
            ‹
          </button>

          <button
            id="next-card"
            type="button"
            aria-label="Næste kort"
            class="absolute right-0 top-0 z-10 font-special text-5xl leading-none text-neutral-black md:text-7xl"
          >
            ›
          </button>

          <!-- card 1 -->
          <div data-card>

            <Heading type="h2" stylingclasses="pb-4 text-center">
              NO. 5
            </Heading>

            <article class="bg-accent-beige px-5 py-7 text-neutral-black shadow-[0_10px_30px_rgba(0,0,0,0.14)] md:px-11 md:py-12">

              <h2 class="font-space text-[24px] font-bold md:text-[28px]">
                BELMA'S BEER SELECTION
              </h2>

              <div class="mt-8 space-y-4 font-special text-[14px] md:mt-10 md:text-[16px]">

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Carlsberg Pilsner</span>
                  <span>25cl/50cl</span>
                  <span>38kr/60kr</span>
                </div>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Tuborg Classic</span>
                  <span>25cl/50cl</span>
                  <span>42kr/68kr</span>
                </div>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Kronenbourg</span>
                  <span>25cl/50cl</span>
                  <span>48kr/78kr</span>
                </div>

                <p>-----------------------------------</p>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Jacobsen</span>
                  <span>40cl</span>
                  <span>78kr</span>
                </div>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Brooklyn</span>
                  <span>40cl</span>
                  <span>78kr</span>
                </div>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Grimbergen</span>
                  <span>50cl</span>
                  <span>78kr</span>
                </div>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Erdinger Weiss</span>
                  <span>50cl</span>
                  <span>82kr</span>
                </div>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Guinness</span>
                  <span>50cl</span>
                  <span>82kr</span>
                </div>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Mikkeller</span>
                  <span>40cl</span>
                  <span>88kr</span>
                </div>

                <div class="grid grid-cols-[1fr_auto_auto] gap-3 md:gap-6">
                  <span>Non-alcoholic</span>
                  <span>40cl</span>
                  <span>78kr</span>
                </div>

                <p>-----------------------------------</p>

                <p class="pt-8 text-center md:pt-10">
                  *ASK US FOR WHAT'S IN ROTATION*
                </p>

              </div>

              <p class="pt-14 text-right font-special text-[28px] md:pt-20 md:text-[40px]">
                Beers
              </p>

            </article>
          </div>

          <!-- card 2 -->
          <div data-card class="hidden">

            <Heading type="h2" stylingclasses="pb-4 text-center">
              NO. 6
            </Heading>

            <article class="bg-accent-beige px-5 py-7 text-neutral-black shadow-[0_10px_30px_rgba(0,0,0,0.14)] md:px-11 md:py-12">

              <h2 class="font-space text-[24px] font-bold md:text-[28px]">
                COCKTAILS
              </h2>

              <div class="mt-8 space-y-5 font-special text-[14px] md:mt-10 md:space-y-6 md:text-[16px]">

                <div>
                  <div class="flex items-end gap-1">
                    <span>Provence Negroni</span>
                    <span class="mb-1 grow border-b border-dashed border-neutral-black"></span>
                    <span>145kr</span>
                  </div>

                  <p class="text-[11px] leading-tight md:text-[12px]">
                    Bombay Premier Cru, Campari, Veramouth, Herbs de Provence
                  </p>
                </div>

                <div>
                  <div class="flex items-end gap-1">
                    <span>Martinique Summer</span>
                    <span class="mb-1 grow border-b border-dashed border-neutral-black"></span>
                    <span>125kr</span>
                  </div>

                  <p class="text-[11px] leading-tight md:text-[12px]">
                    Cazadores Tequila, Mango, Lime, Elderflower
                  </p>
                </div>

                <div>
                  <div class="flex items-end gap-1">
                    <span>Rhubarbella</span>
                    <span class="mb-1 grow border-b border-dashed border-neutral-black"></span>
                    <span>125kr</span>
                  </div>

                  <p class="text-[11px] leading-tight md:text-[12px]">
                    Bombay Premier Cru, Rhubarb, Apple, Cinnamon, Lemon, Tonic
                  </p>
                </div>

                <div>
                  <div class="flex items-end gap-1">
                    <span>Macallan Fashioned</span>
                    <span class="mb-1 grow border-b border-dashed border-neutral-black"></span>
                    <span>195kr</span>
                  </div>

                  <p class="text-[11px] leading-tight md:text-[12px]">
                    Macallen 12 y.o Single Malt, Bitters, Sugar
                  </p>
                </div>

                <div>
                  <div class="flex items-end gap-1">
                    <span>Spicy Mamasita</span>
                    <span class="mb-1 grow border-b border-dashed border-neutral-black"></span>
                    <span>145kr</span>
                  </div>

                  <p class="text-[11px] leading-tight md:text-[12px]">
                    Cazadores Tequila, Mezcal, Triple Sec, Lime, Agave, Chilli jam
                  </p>
                </div>

                <p class="pt-6 font-special text-[18px] md:pt-8 md:text-[22px]">
                  Looking for classic cocktails? — Ask us!
                </p>

              </div>

              <p class="pt-14 text-right font-special text-[28px] md:pt-20 md:text-[40px]">
                Cocktails
              </p>

            </article>
          </div>

          <!-- card 3 -->
          <div data-card class="hidden">

            <Heading type="h2" stylingclasses="pb-4 text-center">
              NO. 7
            </Heading>

            <article class="bg-primary px-5 py-7 text-neutral-white shadow-[0_10px_30px_rgba(0,0,0,0.14)] md:px-11 md:py-12">

              <h2 class="font-space text-[24px] font-bold md:text-[28px]">
                WINE
              </h2>

              <div class="mt-8 space-y-5 font-special text-[14px] md:mt-10 md:text-[16px]">

                <p>SPARKLING</p>

                <div class="flex items-end gap-1 text-[14px]">
                  <span class="max-w-55 md:max-w-85">
                    NV - Moingeon, Cremant - Aligote/Chardonnay/Pinot Noir
                  </span>

                  <span class="mb-1 grow border-b border-dashed border-neutral-white"></span>

                  <span>110 / 500kr</span>
                </div>

                <p class="pt-8">WHITE</p>

                <div class="flex items-end gap-1 text-[14px]">
                  <span class="max-w-55 md:max-w-85">
                    2022 - Gorgee de Soleil - Chardonnay
                  </span>

                  <span class="mb-1 grow border-b border-dashed border-neutral-white"></span>

                  <span>68 / 300kr</span>
                </div>

                <p class="pt-8 leading-tight">
                  B = Biodynamic<br />
                  N = Neutral<br />
                  O = Organic
                </p>

              </div>

              <p class="pt-14 text-right font-special text-[28px] md:pt-20 md:text-[40px]">
                Wines & Bottles
              </p>

            </article>
          </div>

        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    const cards = document.querySelectorAll('[data-card]');
    const prev = document.querySelector('#prev-card');
    const next = document.querySelector('#next-card');

    let currentCard = 0;

    function showCard(index) {
      cards[currentCard].classList.add('hidden');
      currentCard = index;
      cards[currentCard].classList.remove('hidden');
    }

    prev?.addEventListener('click', () => {
      showCard(currentCard === 0 ? cards.length - 1 : currentCard - 1);
    });

    next?.addEventListener('click', () => {
      showCard(currentCard === cards.length - 1 ? 0 : currentCard + 1);
    });
  </script>

</Layout>