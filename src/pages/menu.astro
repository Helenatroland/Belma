---
import Layout from '../layouts/Layout.astro';
import Heading from '../components/heading.astro';
import Text from '../components/text.astro';
import bread from '../img/bread.svg';
import pancakes from '../img/pancakes.svg';
import glass from '../img/glass.svg';
import menu from '../img/menu_page_img.png';
---

<Layout title="Menu">
  <main>
    <!-- section 1 -->
    <section class="w-full px-4 md:px-8 lg:px-12">
      <div class="mx-auto max-w-245">
        <Heading type="h1" stylingclasses="text-center pt-12 md:pt-16 pb-14">
          BELMAS SELECTION
        </Heading>

        <Text>
          Explore our menu and discover a carefully curated selection of food and drinks made for every moment of the day. Start your morning with breakfast favourites, fresh coffee, and something sweet, or stop by later for lunch, light bites, cocktails, wine, and snacks to share. Whether you are visiting for a slow morning, an afternoon break, or an evening out, there is always something to enjoy at Belma.
        </Text>

        <div class="flex items-center justify-center gap-10 py-12">
          <img src={bread.src} alt="" class="h-36 w-auto" />
          <img src={glass.src} alt="" class="h-36 w-auto" />
          <img src={pancakes.src} alt="" class="h-36 w-auto" />
        </div>

        <Heading type="h3" stylingclasses="font-medium py-5">
          Choose a category below and find your next favourite at Belma.
        </Heading>
      </div>
    </section>

    <!-- section 2 -->
    <section class="w-full px-4 pt-6 pb-28 md:px-8 md:pb-36 lg:px-12">
      <div class="mx-auto max-w-245 border border-primary">
        <!-- box 1 -->
        <a
          href="/to_eat"
          class="block border-b border-primary px-6 py-4 transition-colors hover:bg-cta-hover md:flex md:min-h-18 md:items-center md:justify-between"
        >
          <div>
            <Heading type="labelLarge" stylingclasses="leading-none">
              TO EAT
            </Heading>

            <Heading type="graphic" stylingclasses="mt-3 leading-none">
              BREAKFAST, LUNCH, ALL DAY DISHES, & SNACKS
            </Heading>
          </div>

          <div class="mt-5 md:mt-0">
            <Heading type="labelLarge" stylingclasses="leading-none">
              NO. 1 - 2
            </Heading>
          </div>
        </a>

        <!-- box 2 -->
        <a
          href="/sober_sips"
          class="block border-b border-primary px-6 py-4 transition-colors hover:bg-cta-hover md:flex md:min-h-18 md:items-center md:justify-between"
        >
          <div>
            <Heading type="labelLarge" stylingclasses="leading-none">
              SOBER SIPS
            </Heading>

            <Heading type="graphic" stylingclasses="mt-3 leading-none">
              SODA, TEA, COFFEE & OTHER NON-ALCOHOLIC BEVERAGES
            </Heading>
          </div>

          <div class="mt-5 md:mt-0">
            <Heading type="labelLarge" stylingclasses="leading-none">
              NO. 3 - 4
            </Heading>
          </div>
        </a>

        <!-- box 3 -->
        <a
          href="/percentages"
          class="block px-6 py-4 transition-colors hover:bg-cta-hover md:flex md:min-h-18 md:items-center md:justify-between"
        >
          <div>
            <Heading type="labelLarge" stylingclasses="leading-none">
              SIPS WITH PERCENTAGES
            </Heading>

            <Heading type="graphic" stylingclasses="mt-3 leading-none">
              BEER, COCKTAILS & WINE (BY GLASS & BOTTLE)
            </Heading>
          </div>

          <div class="mt-5 md:mt-0">
            <Heading type="labelLarge" stylingclasses="leading-none">
              NO. 5 - 8
            </Heading>
          </div>
        </a>
      </div>
    </section>

    <!-- section 3 (img) -->
    <section class="w-full px-4 pb-32 md:px-8 md:pb-40 lg:px-12 lg:pb-48">
      <div class="mx-auto max-w-245">
        <img src={menu.src} alt="" class="w-full" />
      </div>
    </section>
  </main>
</Layout>