---
import Layout from '../layouts/Layout.astro';
import Heading from '../components/heading.astro';
---

<Layout title="To eat">
  <main>

    <section class="w-full px-4 pt-12 pb-20 md:px-8 md:pt-16 md:pb-24 lg:px-12 lg:pt-20 lg:pb-28">

      <div class="mx-auto w-full max-w-125">

        <div class="relative pb-20">

          <!-- arrows -->
          <button
            id="prev-card"
            type="button"
            aria-label="Forrige kort"
            class="absolute left-0 top-0 z-10 font-special text-5xl leading-none text-neutral-black md:text-7xl"
          >
            ‹
          </button>

          <button
            id="next-card"
            type="button"
            aria-label="Næste kort"
            class="absolute right-0 top-0 z-10 font-special text-5xl leading-none text-neutral-black md:text-7xl"
          >
            ›
          </button>

          <!-- card 1 -->
          <div data-card>

            <Heading type="h2" stylingclasses="pb-4 text-center">
              NO. 1
            </Heading>

            <article class="bg-secondary px-5 py-7 text-primary shadow-[0_10px_30px_rgba(0,0,0,0.14)] md:px-11 md:py-12">

              <h2 class="font-space text-[24px] font-bold md:text-[28px]">
                BREAKFAST
              </h2>

              <p class="mt-7 font-special text-[13px] md:mt-9 md:text-[14px]">
                Served from 09.00AM - 12.00PM
              </p>

              <div class="mt-7 space-y-4 font-special text-[14px] md:mt-8 md:text-[16px]">

                <div class="flex items-end gap-1">
                  <span>Croissant</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>35kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Cinnamonbun</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>35kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span class="max-w-45 md:max-w-none">
                    Bun with Gammelknas (Helges ost)
                  </span>

                  <span class="mb-1 grow border-b border-dashed border-primary"></span>

                  <span>45kr</span>
                </div>

                <div class="flex items-end gap-1">

                  <span class="max-w-50 md:max-w-77.5">
                    Youghurt with Chiaseedpudding, Granola and Berries
                  </span>

                  <span class="mb-1 grow border-b border-dashed border-primary"></span>

                  <span>110kr</span>

                </div>

                <div class="flex items-end gap-1">
                  <span class="max-w-45 md:max-w-none">
                    Pancakes with Syrup & Berries
                  </span>

                  <span class="mb-1 grow border-b border-dashed border-primary"></span>

                  <span>110kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Egg Benedicts</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>110kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Croque Monsieur</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>110kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Croque Madame</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>110kr</span>
                </div>

                <div class="pt-5 md:pt-6">

                  <div class="flex items-end gap-1">

                    <span>Breakfast Plate</span>

                    <span class="mb-1 grow border-b border-dashed border-primary"></span>

                    <span>125kr</span>

                  </div>

                  <p class="mt-1 text-[11px] leading-tight md:text-[13px]">
                    Soft Boiled egg<br />
                    Ryebread with Gammelknas (Helges ost)<br />
                    Youghurt with Granola and Berries
                  </p>

                </div>

              </div>

              <p class="pt-24 text-center font-special text-[28px] md:pt-36 md:text-[40px]">
                BREAKFAST
              </p>

            </article>
          </div>

          <!-- card 2 -->
          <div data-card class="hidden">

            <Heading type="h2" stylingclasses="pb-4 text-center">
              NO. 2
            </Heading>

            <article class="bg-secondary px-5 py-7 text-primary shadow-[0_10px_30px_rgba(0,0,0,0.14)] md:px-11 md:py-12">

              <h2 class="font-space text-[24px] font-bold md:text-[28px]">
                TO EAT
              </h2>

              <p class="mt-7 font-special text-[13px] md:mt-9 md:text-[14px]">
                Served from 12.00PM - 10.00PM
              </p>

              <div class="mt-7 space-y-4 font-special text-[14px] md:mt-8 md:text-[16px]">

                <p class="pb-2 md:pb-4">
                  SANDWICHES
                </p>

                <div class="flex items-end gap-1">
                  <span>Jambon Beurre</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>95kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Jambon Grillé</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>125kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Tomate Grillé</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>125kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Parma Baguette</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>135kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span class="max-w-45 md:max-w-none">
                    Grilled Ventricina Focaccia
                  </span>

                  <span class="mb-1 grow border-b border-dashed border-primary"></span>

                  <span>125kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Stratiatella Focaccia</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>125kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Tuna Melt</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>125kr</span>
                </div>

                <p class="py-4 md:py-5">
                  ... all goods from Helges Ost
                </p>

                <p class="pt-5 pb-2 md:pt-6 md:pb-4">
                  POISSON
                </p>

                <div class="flex items-end gap-1">
                  <span>Mussels Escabeche</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>135kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Sardines in Olive Oil</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>135kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Spiced Sardines</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>135kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Tuna in Chili</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>135kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Octopus Marinara</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>155kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Peppered Salmon</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>165kr</span>
                </div>

                <p class="pt-8 pb-2 md:pt-12 md:pb-4">
                  SOUP
                </p>

                <div class="flex items-end gap-1">
                  <span>Soup of the day</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>125kr</span>
                </div>

                <p class="pt-8 pb-2 md:pt-12 md:pb-4">
                  SNACKS
                </p>

                <div class="flex items-end gap-1">
                  <span>Roasted Almonds</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>45kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Green or Black Olives</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>45kr</span>
                </div>

                <div class="flex items-end gap-1">
                  <span>Kettle Chips</span>
                  <span class="mb-1 grow border-b border-dashed border-primary"></span>
                  <span>45kr</span>
                </div>

                <p class="pt-5 md:pt-6">
                  - Combine all 3 - 120kr -
                </p>

              </div>

              <p class="pt-16 font-special text-[28px] md:pt-24 md:text-[40px]">
                BAR BITES
              </p>

            </article>
          </div>

        </div>
      </div>
    </section>

  </main>

  <script is:inline>
    const cards = document.querySelectorAll('[data-card]');
    const prev = document.querySelector('#prev-card');
    const next = document.querySelector('#next-card');

    let currentCard = 0;

    function showCard(index) {
      cards[currentCard].classList.add('hidden');
      currentCard = index;
      cards[currentCard].classList.remove('hidden');
    }

    prev?.addEventListener('click', () => {
      showCard(currentCard === 0 ? cards.length - 1 : currentCard - 1);
    });

    next?.addEventListener('click', () => {
      showCard(currentCard === cards.length - 1 ? 0 : currentCard + 1);
    });
  </script>

</Layout>